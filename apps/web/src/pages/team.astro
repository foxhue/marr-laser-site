---
import BaseLayout from '@layouts/BaseLayout.astro';
import TeamSection from '@components/TeamSection.astro';
import CTABanner from '@components/CTABanner.astro';
import { sanityClient } from '@lib/sanity';
import { teamMembersQuery } from '@lib/queries';
import type { TeamMember } from '@foxhue/shared';

const teamMembers: TeamMember[] = await sanityClient.fetch(teamMembersQuery);
---

<BaseLayout
  title="Our Team"
  description="Meet the qualified team at Marr Laser & Skin Clinic, Paisley. Experienced practitioners dedicated to your care."
>
  <section class="team-intro">
    <div class="container team-intro-inner">
      <p class="eyebrow">The Practitioners</p>
      <h1 class="team-intro-title">Meet Our Team</h1>
      <p class="team-intro-lead">
        Every member of our team is dedicated to delivering safe, effective treatments with personalised care. Get to know the qualified professionals behind MARR Laser & Skin Clinic.
      </p>
    </div>
  </section>

  <TeamSection members={teamMembers} />

  <CTABanner />
</BaseLayout>

<style>
  .team-intro {
    padding-block: var(--space-20) var(--space-12);
    text-align: center;
  }

  .team-intro-inner {
    max-width: 40rem;
    margin-inline: auto;
  }

  .team-intro-title {
    font-family: var(--font-heading);
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-heading-light);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .team-intro-lead {
    font-size: var(--font-size-lg);
    color: var(--color-neutral-600);
    line-height: 1.7;
  }
</style>

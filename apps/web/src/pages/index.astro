---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import { BOOKING_LINK } from '@lib/constants';
import PathwayCards from '@components/PathwayCards.astro';
import ClinicFeature from '@components/ClinicFeature.astro';
import TechnologySection from '@components/TechnologySection.astro';
import ServicesGrid from '@components/ServicesGrid.astro';
import Testimonials from '@components/Testimonials.astro';
import InstagramFeed from '@components/InstagramFeed.astro';
import CTABanner from '@components/CTABanner.astro';
import { sanityClient } from '@lib/sanity';
import {
  siteSettingsQuery,
  featuredServicesQuery,
  testimonialsQuery,
} from '@lib/queries';
import type { SiteSettings, Service, Testimonial } from '@foxhue/shared';

const settings: SiteSettings = await sanityClient.fetch(siteSettingsQuery);
const services: Service[] = await sanityClient.fetch(featuredServicesQuery);
const testimonials: Testimonial[] = await sanityClient.fetch(testimonialsQuery);
---

<BaseLayout>
  <Hero
    eyebrow="Advanced Skin Care"
    heading={settings?.siteName ?? 'MARR Laser & Skin Clinic'}
    tagline={settings?.tagline ?? 'Our wonderful team are highly trained and have all the advanced technology and techniques to support every avenue in laser, skin, aesthetics & even more.'}
    ctaText="Book Consultation"
    ctaUrl={BOOKING_LINK}
    secondaryCtaText="View Treatments"
    secondaryCtaUrl="/services"
  />

  <PathwayCards />

  <ClinicFeature />

  <TechnologySection />

  {services?.length > 0 && (
    <ServicesGrid services={services} heading="Featured Treatments" />
  )}

  {testimonials?.length > 0 && (
    <Testimonials testimonials={testimonials} />
  )}

  <InstagramFeed />

  <CTABanner />
</BaseLayout>

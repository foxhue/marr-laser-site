---
import { SEO } from 'astro-seo';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import BookingOverlay from '@components/BookingOverlay.astro';
import { sanityClient } from '@lib/sanity';
import { siteSettingsQuery } from '@lib/queries';
import { sanityImageUrl } from '@lib/image';
import type { SiteSettings } from '@foxhue/shared';
import '@styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  transparentHeader?: boolean;
}

const { title, description, ogImage, transparentHeader = false } = Astro.props;

const settings: SiteSettings = await sanityClient.fetch(siteSettingsQuery);

const siteTitle = title
  ? `${title} | ${settings?.siteName ?? 'MARR Laser & Skin Clinic'}`
  : settings?.siteName ?? 'MARR Laser & Skin Clinic';

const siteDescription =
  description ?? settings?.defaultSeo?.description ?? '';

const siteOgImage =
  ogImage ??
  (settings?.defaultSeo?.ogImage
    ? sanityImageUrl(settings.defaultSeo.ogImage, 1200, 630)
    : undefined);

const jsonLd = settings
  ? {
      '@context': 'https://schema.org',
      '@type': 'LocalBusiness',
      name: settings.siteName,
      description: siteDescription,
      ...(settings.contactEmail && { email: settings.contactEmail }),
      ...(settings.contactPhone && {
        telephone: settings.contactPhone,
      }),
      ...(settings.address && {
        address: {
          '@type': 'PostalAddress',
          streetAddress: settings.address,
        },
      }),
      ...(settings.openingHours?.length && {
        openingHoursSpecification: settings.openingHours
          .filter((h) => !h.closed)
          .map((h) => ({
            '@type': 'OpeningHoursSpecification',
            dayOfWeek: h.day,
            opens: h.open,
            closes: h.close,
          })),
      }),
    }
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={siteTitle}
      description={siteDescription}
      {...(siteOgImage && {
        openGraph: {
          basic: {
            title: siteTitle,
            type: 'website',
            image: siteOgImage,
          },
        },
      })}
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://www.phorest.com" />
    <!-- TODO: swap heading to Cangste when licensed webfont is available -->
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400&family=Noto+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>

  <body>
    <a href="#main-content" class="skip-link sr-only">Skip to main content</a>
    <Header
      siteName={settings?.siteName ?? 'MARR Laser & Skin Clinic'}
      logo={settings?.logo}
      transparentHeader={transparentHeader}
    />

    <main id="main-content" class:list={[{ 'main--transparent-hero': transparentHeader }]}>
      <slot />
    </main>

    <Footer
      siteName={settings?.siteName ?? 'MARR Laser & Skin Clinic'}
      contactEmail={settings?.contactEmail}
      contactPhone={settings?.contactPhone}
      address={settings?.address}
      socialLinks={settings?.socialLinks}
    />

    <BookingOverlay />
  </body>
</html>

<style>
  .main--transparent-hero {
    margin-top: 0;
    padding-top: 0;
  }

  .skip-link:focus {
    position: fixed;
    top: var(--space-2);
    left: var(--space-2);
    z-index: 9999;
    padding: var(--space-2) var(--space-4);
    background: var(--color-primary);
    color: var(--color-white);
    text-decoration: none;
    border-radius: var(--radius-sm);
    width: auto;
    height: auto;
    clip: auto;
    white-space: normal;
    overflow: visible;
  }
</style>

---
import type { FAQ } from '@foxhue/shared';
import PortableText from '@components/PortableText.astro';

interface Props {
  faqs: FAQ[];
  heading?: string;
}

const { faqs, heading = 'Frequently Asked Questions' } = Astro.props;

/**
 * Group FAQs by category. Items without a category go under "General".
 */
function groupByCategory(items: FAQ[]): Map<string, FAQ[]> {
  const grouped = new Map<string, FAQ[]>();
  for (const faq of items) {
    const cat = faq.category || 'General';
    const list = grouped.get(cat) || [];
    list.push(faq);
    grouped.set(cat, list);
  }
  return grouped;
}

const grouped = groupByCategory(faqs);
const hasCategories = grouped.size > 1 || !grouped.has('General');
---

<section class="faq-section" aria-labelledby="faq-heading">
  <div class="container faq-container">
    <h2 id="faq-heading" class="section-heading">{heading}</h2>
    {faqs.length > 0 ? (
      hasCategories ? (
        Array.from(grouped.entries()).map(([category, items]) => (
          <div class="faq-group">
            <h3 class="faq-group-heading">{category}</h3>
            <div class="faq-list">
              {items.map((faq) => (
                <details class="faq-item">
                  <summary class="faq-question">
                    <span class="faq-question-text">{faq.question}</span>
                    <span class="faq-chevron" aria-hidden="true"></span>
                  </summary>
                  <div class="faq-answer">
                    <PortableText value={faq.answer} />
                  </div>
                </details>
              ))}
            </div>
          </div>
        ))
      ) : (
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-question">
                <span class="faq-question-text">{faq.question}</span>
                <span class="faq-chevron" aria-hidden="true"></span>
              </summary>
              <div class="faq-answer">
                <PortableText value={faq.answer} />
              </div>
            </details>
          ))}
        </div>
      )
    ) : (
      <p class="faq-empty">No FAQs available at this time.</p>
    )}
  </div>
</section>

<style>
  .faq-section {
    padding-block: var(--space-16);
  }

  .faq-container {
    max-width: var(--max-width-narrow);
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-heading-light);
    color: var(--color-neutral-900);
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .faq-group {
    margin-bottom: var(--space-10);
  }

  .faq-group:last-child {
    margin-bottom: 0;
  }

  .faq-group-heading {
    font-family: var(--font-heading);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-heading-regular);
    color: var(--color-neutral-800);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--color-primary);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .faq-item {
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: box-shadow var(--transition-fast);
  }

  .faq-item[open] {
    box-shadow: var(--shadow-sm);
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-6);
    cursor: pointer;
    font-weight: 500;
    color: var(--color-neutral-800);
    list-style: none;
    transition: background-color var(--transition-fast);
  }

  /* Remove default marker in all browsers */
  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::marker {
    content: '';
  }

  .faq-question:hover {
    background-color: var(--color-neutral-50);
  }

  .faq-question:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: -2px;
  }

  .faq-question-text {
    flex: 1;
    font-size: var(--font-size-base);
    line-height: 1.5;
  }

  /* Custom chevron indicator */
  .faq-chevron {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    position: relative;
    transition: transform var(--transition-base);
  }

  .faq-chevron::before,
  .faq-chevron::after {
    content: '';
    position: absolute;
    background-color: var(--color-neutral-500);
    border-radius: 1px;
    transition: transform var(--transition-base);
  }

  /* Horizontal bar */
  .faq-chevron::before {
    top: 50%;
    left: 0;
    width: 100%;
    height: 2px;
    transform: translateY(-50%);
  }

  /* Vertical bar (rotates to form plus/minus) */
  .faq-chevron::after {
    top: 0;
    left: 50%;
    width: 2px;
    height: 100%;
    transform: translateX(-50%);
  }

  /* When open, vertical bar rotates to 90deg forming a minus */
  .faq-item[open] .faq-chevron::after {
    transform: translateX(-50%) rotate(90deg);
  }

  .faq-answer {
    padding: 0 var(--space-6) var(--space-6);
  }

  .faq-answer :global(.prose) {
    font-size: var(--font-size-base);
    color: var(--color-neutral-600);
    line-height: 1.7;
  }

  .faq-empty {
    text-align: center;
    color: var(--color-neutral-500);
    font-size: var(--font-size-lg);
  }
</style>

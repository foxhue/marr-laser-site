---
import type { Testimonial } from '@foxhue/shared';

interface Props {
  testimonials: Testimonial[];
  heading?: string;
}

const { testimonials, heading = 'In Their Own Words' } = Astro.props;
---

<section class="testimonials" aria-labelledby="testimonials-heading">
  <div class="container">
    <div class="testimonials__head">
      <span class="eyebrow">Patient Stories</span>
      <h2 id="testimonials-heading" class="testimonials__heading">{heading}</h2>
    </div>
    {testimonials.length > 0 ? (
      <div class="testimonials__grid" role="list">
        {testimonials.map((t) => (
          <article class="testimonial" role="listitem">
            <div class="testimonial__quote-mark" aria-hidden="true">&ldquo;</div>
            <p class="testimonial__body">{t.quote}</p>
            <footer class="testimonial__attr">
              <div class="testimonial__name">{t.author}</div>
              {t.service?.title && (
                <div class="testimonial__context">{t.service.title}</div>
              )}
            </footer>
          </article>
        ))}
      </div>
    ) : (
      <p class="testimonials__empty">No testimonials yet.</p>
    )}
  </div>
</section>

<style>
  .testimonials {
    background-color: var(--color-secondary);
    padding-block: var(--space-20);
  }

  .testimonials__head {
    text-align: center;
    max-width: 48ch;
    margin: 0 auto var(--space-12);
  }

  .testimonials__head .eyebrow {
    color: rgba(255, 255, 255, 0.7);
  }

  .testimonials__heading {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-light);
    font-size: var(--font-size-3xl);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-white);
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  .testimonial {
    position: relative;
    background-color: var(--color-white);
    padding: var(--space-10) var(--space-8) var(--space-8);
    border-radius: var(--radius-md);
  }

  .testimonial__quote-mark {
    position: absolute;
    top: var(--space-4);
    left: var(--space-6);
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-light);
    font-size: 4.5rem;
    line-height: 1;
    color: var(--color-secondary);
    user-select: none;
  }

  .testimonial__body {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-light);
    font-style: italic;
    font-size: var(--font-size-lg);
    line-height: 1.55;
    color: var(--color-primary);
    margin-bottom: var(--space-6);
  }

  .testimonial__attr {
    border-top: 1px solid rgba(60, 60, 59, 0.12);
    padding-top: var(--space-4);
  }

  .testimonial__name {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-regular);
    font-size: 0.6875rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-1);
  }

  .testimonial__context {
    font-family: var(--font-body);
    font-style: italic;
    font-size: var(--font-size-sm);
    color: var(--color-neutral-600);
  }

  .testimonials__empty {
    text-align: center;
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--font-size-lg);
  }

  @media (min-width: 768px) {
    .testimonials__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .testimonials__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

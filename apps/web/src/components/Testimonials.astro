---
import type { Testimonial } from '@foxhue/shared';

interface Props {
  testimonials: Testimonial[];
  heading?: string;
}

const { testimonials, heading = 'What Our Clients Say' } = Astro.props;

/**
 * Render a star rating as a string of filled and empty star characters.
 * Returns 5 characters total. Accessible text is provided via aria-label.
 */
function renderStars(rating: number | undefined): string {
  if (!rating) return '';
  const filled = Math.round(Math.min(Math.max(rating, 0), 5));
  return '\u2605'.repeat(filled) + '\u2606'.repeat(5 - filled);
}
---

<section class="testimonials-section" aria-labelledby="testimonials-heading">
  <div class="container">
    <h2 id="testimonials-heading" class="section-heading">{heading}</h2>
    {testimonials.length > 0 ? (
      <div class="testimonials-scroll" role="list">
        {testimonials.map((t) => {
          const stars = renderStars(t.rating);
          return (
            <blockquote class="testimonial-card" role="listitem">
              <div class="testimonial-quote-mark" aria-hidden="true">&ldquo;</div>
              <p class="testimonial-text">{t.quote}</p>
              <footer class="testimonial-footer">
                {stars && (
                  <div
                    class="testimonial-stars"
                    role="img"
                    aria-label={`Rating: ${t.rating} out of 5 stars`}
                  >
                    {stars}
                  </div>
                )}
                <cite class="testimonial-author">{t.author}</cite>
                {t.service?.title && (
                  <span class="testimonial-service">{t.service.title}</span>
                )}
              </footer>
            </blockquote>
          );
        })}
      </div>
    ) : (
      <p class="testimonials-empty">No testimonials yet.</p>
    )}
  </div>
</section>

<style>
  .testimonials-section {
    padding-block: var(--space-16);
    background-color: var(--color-neutral-50);
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: var(--font-size-3xl);
    font-weight: 700;
    color: var(--color-neutral-900);
    text-align: center;
    margin-bottom: var(--space-12);
  }

  /* Mobile: horizontal scroll */
  .testimonials-scroll {
    display: flex;
    gap: var(--space-6);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding: var(--space-4);
    padding-bottom: var(--space-4);
    -webkit-overflow-scrolling: touch;
  }

  /* Hide scrollbar for cleaner look while keeping functionality */
  .testimonials-scroll::-webkit-scrollbar {
    height: 6px;
  }

  .testimonials-scroll::-webkit-scrollbar-track {
    background: var(--color-neutral-200);
    border-radius: var(--radius-full);
  }

  .testimonials-scroll::-webkit-scrollbar-thumb {
    background: var(--color-neutral-400);
    border-radius: var(--radius-full);
  }

  .testimonial-card {
    flex: 0 0 85%;
    scroll-snap-align: start;
    background-color: var(--color-white);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    border-left: 4px solid var(--color-primary);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .testimonial-quote-mark {
    font-size: 3rem;
    line-height: 1;
    color: var(--color-primary-light);
    font-family: Georgia, serif;
  }

  .testimonial-text {
    font-size: var(--font-size-base);
    line-height: 1.7;
    color: var(--color-neutral-700);
    flex: 1;
  }

  .testimonial-footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-top: auto;
  }

  .testimonial-stars {
    font-size: var(--font-size-lg);
    color: var(--color-secondary);
    letter-spacing: 0.1em;
  }

  .testimonial-author {
    font-style: normal;
    font-weight: 600;
    color: var(--color-neutral-900);
    font-size: var(--font-size-base);
  }

  .testimonial-service {
    font-size: var(--font-size-sm);
    color: var(--color-neutral-500);
  }

  .testimonials-empty {
    text-align: center;
    color: var(--color-neutral-500);
    font-size: var(--font-size-lg);
  }

  /* Tablet: 2-column grid */
  @media (min-width: 768px) {
    .testimonials-scroll {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      overflow-x: visible;
      scroll-snap-type: none;
      padding-bottom: 0;
    }

    .testimonial-card {
      flex: none;
    }
  }
</style>

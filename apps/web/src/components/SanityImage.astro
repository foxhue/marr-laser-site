---
import type { SanityImage as SanityImageType } from '@foxhue/shared';
import { sanityImageUrl } from '@lib/image';

interface Props {
  source: SanityImageType | undefined | null;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const { source, alt, width, height, class: className, loading = 'lazy', fetchpriority } = Astro.props;

const src = source ? sanityImageUrl(source, width, height) : null;
---

{src && (
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    decoding={loading === 'eager' ? 'sync' : 'async'}
    fetchpriority={fetchpriority}
    class={className}
  />
)}

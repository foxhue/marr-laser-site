---
import type { SocialLink } from '@foxhue/shared';

interface Props {
  siteName: string;
  contactEmail?: string;
  contactPhone?: string;
  address?: string;
  socialLinks?: SocialLink[];
}

const { siteName, contactEmail, contactPhone, address, socialLinks } = Astro.props;

const quickLinks = [
  { label: 'Home', href: '/' },
  { label: 'Treatments', href: '/services' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'About', href: '/about' },
  { label: 'Team', href: '/team' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const currentYear = new Date().getFullYear();

const socialIcons: Record<string, string> = {
  facebook: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
  instagram: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  twitter: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>`,
  linkedin: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
  tiktok: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>`,
  youtube: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg>`,
};
---

<footer class="site-footer">
  <div class="footer-inner container">
    <div class="footer-grid">
      <!-- Brand column -->
      <div class="footer-col footer-brand">
        <a href="/" class="footer-logo-link" aria-label={`${siteName} - Home`}>
          <img src="/logos/marr-wordmark-light.svg" alt={siteName} class="footer-logo" width="220" height="52" />
        </a>
        <p class="footer-blurb">Advanced laser technology and expert skin treatments, tailored to you.</p>
        {socialLinks && socialLinks.length > 0 && (
          <ul class="social-links" role="list" aria-label="Social media links">
            {socialLinks.map((link) => (
              <li>
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="social-link"
                  aria-label={`Follow us on ${link.platform}`}
                >
                  <Fragment set:html={socialIcons[link.platform] ?? link.platform} />
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>

      <!-- Quick links column -->
      <div class="footer-col">
        <h4 class="eyebrow">Quick Links</h4>
        <ul class="footer-links" role="list">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div class="footer-col">
        <h4 class="eyebrow">Contact</h4>
        <address class="footer-contact">
          {contactEmail && (
            <p>
              <a href={`mailto:${contactEmail}`} class="footer-link">
                {contactEmail}
              </a>
            </p>
          )}
          {contactPhone && (
            <p>
              <a href={`tel:${contactPhone.replace(/\s/g, '')}`} class="footer-link">
                {contactPhone}
              </a>
            </p>
          )}
          {address && (
            <p class="footer-address">{address}</p>
          )}
        </address>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} {siteName}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-primary);
    color: var(--color-neutral-100);
    padding: var(--space-20) var(--space-8);
    margin-top: var(--space-24);
  }

  .footer-grid {
    display: grid;
    gap: var(--space-12);
  }

  @media (max-width: 767px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr;
    }
  }

  /* Brand */
  .footer-logo-link {
    text-decoration: none;
    display: inline-block;
  }

  .footer-logo {
    height: 3rem;
    width: auto;
    margin-bottom: var(--space-4);
  }

  .footer-blurb {
    font-size: var(--font-size-sm);
    color: rgba(249, 249, 248, 0.5);
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }

  /* Social links */
  .social-links {
    display: flex;
    gap: var(--space-3);
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    color: rgba(249, 249, 248, 0.5);
    background-color: rgba(249, 249, 248, 0.1);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: color var(--transition-fast), background-color var(--transition-fast);
  }

  .social-link:hover {
    color: var(--color-white);
    background-color: var(--color-secondary);
  }

  /* Headings */
  .site-footer .eyebrow {
    color: var(--color-secondary);
    margin-bottom: var(--space-5);
  }

  /* Links */
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-link {
    color: rgba(249, 249, 248, 0.7);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--color-white);
  }

  /* Contact */
  .footer-contact {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-address {
    color: rgba(249, 249, 248, 0.7);
    line-height: 1.5;
  }

  /* Bottom */
  .footer-bottom {
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-secondary);
    font-size: var(--font-size-xs);
    color: rgba(249, 249, 248, 0.4);
  }
</style>

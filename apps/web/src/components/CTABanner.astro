---
import { BOOKING_LINK } from '@lib/constants';

interface Props {
  heading: string;
  text?: string;
  buttonText?: string;
  buttonUrl?: string;
  style?: 'primary' | 'secondary';
}

const {
  heading = 'Ready to Start Your Treatment Journey?',
  text = 'Book a free consultation to discuss your goals with our expert team.',
  buttonText = 'Book a Consultation',
  buttonUrl = BOOKING_LINK,
  style = 'primary',
} = Astro.props;
---

<section class:list={['cta-banner', `cta-banner--${style}`]}>
  <div class="container cta-inner">
    <h2 class="cta-heading">{heading}</h2>
    {text && <p class="cta-text">{text}</p>}
    <a href={buttonUrl} class="cta-button" {...(buttonUrl.includes('phorest') && { 'data-booking': '' })}>
      {buttonText}
    </a>
  </div>
</section>

<style>
  .cta-banner {
    padding-block: var(--space-16);
  }

  .cta-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .cta-heading {
    font-family: var(--font-heading);
    font-size: var(--font-size-3xl);
    font-weight: 400;
    line-height: 1.2;
  }

  .cta-text {
    font-size: var(--font-size-lg);
    line-height: 1.6;
    max-width: 36rem;
  }

  .cta-button {
    display: inline-block;
    margin-top: var(--space-4);
    padding: var(--space-3) var(--space-10);
    font-size: var(--font-size-sm);
    font-weight: 500;
    text-decoration: none;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: var(--radius-full);
    transition: background-color var(--transition-fast), box-shadow var(--transition-fast), color var(--transition-fast);
  }

  .cta-button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* Primary style: colored background, white text */
  .cta-banner--primary {
    background-color: var(--color-primary);
  }

  .cta-banner--primary .cta-heading {
    color: var(--color-white);
  }

  .cta-banner--primary .cta-text {
    color: color-mix(in srgb, var(--color-white) 85%, transparent);
  }

  .cta-banner--primary .cta-button {
    color: var(--color-primary);
    background-color: var(--color-white);
  }

  .cta-banner--primary .cta-button:hover {
    background-color: var(--color-neutral-100);
    box-shadow: var(--shadow-md);
  }

  /* Secondary style: neutral background, dark text */
  .cta-banner--secondary {
    background-color: var(--color-neutral-100);
  }

  .cta-banner--secondary .cta-heading {
    color: var(--color-neutral-900);
  }

  .cta-banner--secondary .cta-text {
    color: var(--color-neutral-600);
  }

  .cta-banner--secondary .cta-button {
    color: var(--color-white);
    background-color: var(--color-primary);
  }

  .cta-banner--secondary .cta-button:hover {
    background-color: var(--color-primary-dark);
    box-shadow: var(--shadow-md);
  }

  /* Responsive */
  @media (min-width: 768px) {
    .cta-banner {
      padding-block: var(--space-20);
    }

    .cta-heading {
      font-size: var(--font-size-4xl);
    }
  }
</style>

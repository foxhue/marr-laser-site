---
import { BOOKING_LINK } from '@lib/constants';

interface Props {
  eyebrow?: string;
  heading?: string;
  body?: string;
  ctaText?: string;
  ctaUrl?: string;
}

const {
  eyebrow,
  heading = 'Ready to Start Your Treatment Journey?',
  body = 'Book a free consultation to discuss your goals with our expert team.',
  ctaText = 'Book a Consultation',
  ctaUrl = BOOKING_LINK,
} = Astro.props;
---

<section class="cta-banner" aria-labelledby="cta-banner-heading">
  <div class="container cta-banner__inner">
    {eyebrow && <span class="eyebrow cta-banner__eyebrow">{eyebrow}</span>}
    <h2 id="cta-banner-heading" class="cta-banner__heading">{heading}</h2>
    {body && <p class="cta-banner__body">{body}</p>}
    <a href={ctaUrl} class="cta-banner__btn" {...(ctaUrl?.includes('phorest') && { 'data-booking': '' })}>
      {ctaText}
    </a>
  </div>
</section>

<style>
  .cta-banner {
    background-color: var(--color-secondary);
    color: var(--color-white);
    padding-block: var(--space-20);
    text-align: center;
  }
  .cta-banner__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .cta-banner__eyebrow {
    color: rgba(255, 255, 255, 0.7);
  }
  .cta-banner__heading {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-light);
    font-size: var(--font-size-4xl);
    line-height: 1.15;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-white);
    margin-bottom: var(--space-5);
    max-width: 32ch;
    margin-inline: auto;
  }
  .cta-banner__body {
    max-width: 52ch;
    margin-inline: auto;
    margin-bottom: var(--space-8);
    font-size: var(--font-size-lg);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.85);
  }
  .cta-banner__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-8);
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-regular);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background-color: var(--color-white);
    color: var(--color-primary);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: background-color var(--transition-base);
  }
  .cta-banner__btn:hover {
    background-color: var(--color-accent);
  }
  .cta-banner__btn:focus-visible {
    outline: 2px solid var(--color-white);
    outline-offset: 2px;
  }
</style>

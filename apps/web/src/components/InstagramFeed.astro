---
const instagramUrl = 'https://www.instagram.com/marrlaserandskin';
const handle = '@marrlaserandskin';

const photos = [
  { src: '/images/instagram/facial-treatment.jpg', alt: 'Professional facial treatment' },
  { src: '/images/instagram/skin-portrait.jpg', alt: 'Radiant skin close-up' },
  { src: '/images/instagram/skincare-products.jpg', alt: 'Luxury skincare products' },
  { src: '/images/instagram/clinic-reception.jpg', alt: 'MARR clinic reception' },
  { src: '/images/instagram/laser-treatment.jpg', alt: 'Laser treatment session' },
  { src: '/images/instagram/treatment-bed.jpg', alt: 'Relaxing treatment experience' },
];
---

<section class="instagram-section" aria-labelledby="instagram-heading">
  <div class="container">
    <h2 id="instagram-heading" class="section-heading">Follow Us on Instagram</h2>
    <p class="section-handle">{handle}</p>

    <!-- Replace with Elfsight/SnapWidget embed when ready -->
    <div class="instagram-grid">
      {photos.map((photo) => (
        <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="instagram-item" aria-label={`${photo.alt} - View on Instagram (opens in new tab)`}>
          <img src={photo.src} alt="" class="instagram-photo" loading="lazy" decoding="async" width="400" height="400" />
        </a>
      ))}
    </div>

    <div class="instagram-cta">
      <a href={instagramUrl} target="_blank" rel="noopener" class="instagram-button">
        Follow {handle}<span class="sr-only"> (opens in new tab)</span>
      </a>
    </div>
  </div>
</section>

<style>
  .instagram-section {
    padding-block: var(--space-20);
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-heading-light);
    color: var(--color-primary);
    text-align: center;
    margin-bottom: var(--space-2);
  }

  .section-handle {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    color: var(--color-neutral-500);
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .instagram-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
    max-width: 48rem;
    margin-inline: auto;
  }

  .instagram-item {
    display: block;
    aspect-ratio: 1;
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .instagram-item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .instagram-item:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .instagram-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-base);
  }

  .instagram-item:hover .instagram-photo {
    transform: scale(1.05);
  }

  .instagram-cta {
    text-align: center;
    margin-top: var(--space-8);
  }

  .instagram-button {
    display: inline-block;
    padding: var(--space-3) var(--space-8);
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: var(--font-weight-heading-regular);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-white);
    background-color: var(--color-primary);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: background-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .instagram-button:hover {
    background-color: var(--color-primary-dark);
    box-shadow: var(--shadow-md);
  }

  .instagram-button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  @media (min-width: 768px) {
    .instagram-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .section-heading {
      font-size: var(--font-size-4xl);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .instagram-item,
    .instagram-photo {
      transition: none;
    }
  }
</style>

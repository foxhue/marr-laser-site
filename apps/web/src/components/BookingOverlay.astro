---
/**
 * BookingOverlay — full-screen iframe overlay for Phorest booking.
 * Provides a persistent floating "Book Now" button and intercepts
 * all [data-booking] links to open the overlay instead of navigating away.
 */
import { BOOKING_URL, BOOKING_LINK } from '@lib/constants';

const bookingUrl = BOOKING_URL;
---

<!-- Floating Book Now button (anchor for progressive enhancement — works without JS) -->
<a
  href={BOOKING_LINK}
  class="booking-fab"
  data-booking
  aria-label="Book Now"
>
  <svg class="booking-fab-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
    <line x1="16" y1="2" x2="16" y2="6"></line>
    <line x1="8" y1="2" x2="8" y2="6"></line>
    <line x1="3" y1="10" x2="21" y2="10"></line>
  </svg>
  <span class="booking-fab-label">Book Now</span>
</a>

<!-- Overlay -->
<div class="booking-overlay" id="booking-overlay" role="dialog" aria-modal="true" aria-labelledby="booking-dialog-title" hidden>
  <div class="booking-backdrop" data-booking-close></div>
  <div class="booking-panel">
    <div class="booking-panel-header">
      <h2 class="booking-panel-title" id="booking-dialog-title">Book an Appointment</h2>
      <button type="button" class="booking-close" data-booking-close aria-label="Close booking">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="booking-panel-body">
      <div class="booking-loader" id="booking-loader">
        <div class="booking-spinner"></div>
        <p class="booking-loader-text">Loading booking...</p>
      </div>
      <iframe
        id="booking-iframe"
        title="Phorest online booking for MARR Laser & Skin Clinic"
        allow="payment"
        sandbox="allow-scripts allow-same-origin allow-forms allow-popups"
        referrerpolicy="strict-origin"
      ></iframe>
    </div>
  </div>
</div>

<style>
  /* Floating action button */
  .booking-fab {
    position: fixed;
    bottom: var(--space-6);
    right: var(--space-6);
    z-index: 90;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: var(--font-weight-heading-regular);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-white);
    background-color: var(--color-primary);
    border: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(60, 60, 59, 0.3);
    transition: background-color var(--transition-fast), transform var(--transition-fast);
    will-change: transform;
  }

  .booking-fab:hover {
    background-color: var(--color-primary-dark);
    box-shadow: 0 6px 28px rgba(60, 60, 59, 0.4);
    transform: translateY(-2px);
  }

  .booking-fab:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  .booking-fab:active {
    transform: translateY(0);
  }

  .booking-fab-icon {
    flex-shrink: 0;
  }

  /* Overlay */
  .booking-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .booking-overlay[hidden] {
    display: none;
  }

  .booking-backdrop {
    position: absolute;
    inset: 0;
    background-color: rgba(30, 30, 30, 0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    animation: fadeIn 250ms ease;
  }

  /* Panel */
  .booking-panel {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 95vh;
    max-width: 520px;
    background-color: var(--color-white);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    box-shadow: 0 -4px 40px rgba(0, 0, 0, 0.15);
    animation: slideUp 300ms ease;
    overflow: hidden;
  }

  .booking-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-6);
    border-bottom: 1px solid var(--color-accent);
    flex-shrink: 0;
  }

  .booking-panel-title {
    font-family: var(--font-heading);
    font-size: var(--font-size-xl);
    font-weight: 400;
    color: var(--color-primary);
  }

  .booking-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: none;
    background: none;
    color: var(--color-neutral-500);
    border-radius: var(--radius-full);
    cursor: pointer;
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .booking-close:hover {
    background-color: var(--color-accent);
    color: var(--color-primary);
  }

  .booking-close:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .booking-panel-body {
    position: relative;
    flex: 1;
    overflow: hidden;
  }

  /* Iframe */
  #booking-iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  /* Loader */
  .booking-loader {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    background-color: var(--color-white);
  }

  .booking-loader.is-hidden {
    opacity: 0;
    pointer-events: none;
    transition: opacity 300ms ease;
  }

  .booking-spinner {
    width: 2rem;
    height: 2rem;
    border: 2px solid var(--color-accent);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  .booking-loader-text {
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    color: var(--color-neutral-500);
  }

  /* Animations */
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideUp {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Desktop — centered modal instead of bottom sheet */
  @media (min-width: 768px) {
    .booking-overlay {
      align-items: center;
    }

    .booking-panel {
      height: 85vh;
      max-height: 900px;
      border-radius: var(--radius-lg);
      animation: scaleIn 250ms ease;
    }
  }

  @keyframes scaleIn {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(10px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .booking-backdrop,
    .booking-panel,
    .booking-fab {
      animation: none;
      transition: none;
    }

    .booking-backdrop {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background-color: rgba(30, 30, 30, 0.7);
    }
  }
</style>

<script define:vars={{ bookingUrl }}>
  const overlay = document.getElementById('booking-overlay');
  const iframe = document.getElementById('booking-iframe');
  const loader = document.getElementById('booking-loader');
  let isOpen = false;
  let iframeLoaded = false;
  let previousFocus = null;

  function openBooking() {
    if (isOpen) return;
    isOpen = true;
    previousFocus = document.activeElement;

    // Load iframe on first open (lazy)
    if (!iframeLoaded) {
      iframe.src = bookingUrl;
      iframe.addEventListener('load', () => {
        loader.classList.add('is-hidden');
        iframeLoaded = true;
      }, { once: true });
      // Timeout fallback — hide spinner after 15s even if load event doesn't fire
      setTimeout(() => {
        if (!iframeLoaded) {
          loader.classList.add('is-hidden');
          iframeLoaded = true;
        }
      }, 15000);
    } else {
      loader.classList.add('is-hidden');
    }

    overlay.hidden = false;
    document.body.style.overflow = 'hidden';

    // Focus the close button for accessibility
    requestAnimationFrame(() => {
      overlay.querySelector('[data-booking-close]:last-of-type')?.focus();
    });
  }

  function closeBooking() {
    if (!isOpen) return;
    isOpen = false;
    overlay.hidden = true;
    document.body.style.overflow = '';

    // Restore focus to the element that opened the dialog
    if (previousFocus && previousFocus.focus) {
      previousFocus.focus();
      previousFocus = null;
    }
  }

  // Focus trap — keep Tab cycling within the overlay
  function trapFocus(e) {
    if (e.key !== 'Tab' || !isOpen) return;
    const focusable = overlay.querySelectorAll(
      'button, [href], iframe, [tabindex]:not([tabindex="-1"])'
    );
    if (!focusable.length) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  }

  // Close buttons + backdrop
  document.querySelectorAll('[data-booking-close]').forEach((el) => {
    el.addEventListener('click', closeBooking);
  });

  // Escape key + focus trap
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closeBooking();
    trapFocus(e);
  });

  // Intercept all [data-booking] links
  document.addEventListener('click', (e) => {
    const link = e.target.closest('[data-booking]');
    if (link) {
      e.preventDefault();
      openBooking();
    }
  });
</script>

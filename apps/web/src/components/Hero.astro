---
import type { SanityImage as SanityImageType } from '@foxhue/shared';
import { sanityImageUrl } from '@lib/image';

interface Props {
  heading: string;
  tagline?: string;
  image?: SanityImageType;
  ctaText?: string;
  ctaUrl?: string;
  eyebrow?: string;
  secondaryCtaText?: string;
  secondaryCtaUrl?: string;
}

const { heading, tagline, image, ctaText, ctaUrl, eyebrow, secondaryCtaText, secondaryCtaUrl } = Astro.props;

const bgImageUrl = image ? sanityImageUrl(image, 1200, 900) : null;
---

<section class="hero" aria-label="Hero">
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-content-inner">
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        <h1 class="hero-heading">{heading}</h1>
        {tagline && <p class="hero-tagline">{tagline}</p>}
        <div class="hero-cta-group">
          {ctaText && ctaUrl && (
            <a href={ctaUrl} class="hero-cta hero-cta--primary"
               {...(ctaUrl?.includes('phorest') && { 'data-booking': '' })}>
              {ctaText}
            </a>
          )}
          {secondaryCtaText && secondaryCtaUrl && (
            <a href={secondaryCtaUrl} class="hero-cta hero-cta--outline">
              {secondaryCtaText}
            </a>
          )}
        </div>
      </div>
    </div>
    <div class="hero-media">
      {bgImageUrl ? (
        <img
          src={bgImageUrl}
          alt={heading}
          class="hero-image"
          loading="eager"
          decoding="async"
        />
      ) : (
        <img src="/images/hero.jpg" alt="MARR Laser & Skin Clinic" class="hero-image" loading="eager" decoding="async" fetchpriority="high" width="1600" height="1600" />
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 70vh;
  }

  /* Content panel — blush/accent background */
  .hero-content {
    background-color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-12) var(--space-6);
  }

  .hero-content-inner {
    max-width: 32rem;
  }

  .hero-heading {
    font-family: var(--font-heading);
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-heading-light);
    line-height: 1.15;
    color: var(--color-primary);
    margin-bottom: var(--space-5);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-body-light);
    line-height: 1.65;
    color: var(--color-neutral-600);
    margin-bottom: var(--space-8);
    letter-spacing: var(--body-letter-spacing);
  }

  .hero-cta-group {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-8);
    font-family: var(--font-heading);
    font-weight: var(--font-weight-heading-regular);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: var(--radius-lg);
    text-decoration: none;
    border: 1px solid transparent;
    transition: background-color var(--transition-base), color var(--transition-base);
  }

  .hero-cta--primary {
    background-color: var(--color-secondary);
    color: var(--color-white);
    border-color: var(--color-secondary);
  }

  .hero-cta--primary:hover {
    background-color: var(--color-secondary-dark);
  }

  .hero-cta--outline {
    background-color: transparent;
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .hero-cta--outline:hover {
    background-color: var(--color-primary);
    color: var(--color-white);
  }

  .hero-cta:focus-visible {
    outline: 2px solid var(--color-secondary);
    outline-offset: 2px;
  }

  /* Media panel — image side */
  .hero-media {
    position: relative;
    overflow: hidden;
    min-height: 300px;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Desktop: side-by-side split layout */
  @media (min-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr 1fr;
      min-height: 75vh;
    }

    .hero-content {
      padding: var(--space-16) var(--space-12);
    }

    .hero-heading {
      font-size: var(--font-size-5xl);
    }

    .hero-tagline {
      font-size: var(--font-size-lg);
    }
  }

  @media (min-width: 1024px) {
    .hero-content {
      padding: var(--space-20) var(--space-16);
    }
  }
</style>

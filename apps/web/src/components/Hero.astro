---
import type { SanityImage as SanityImageType } from '@foxhue/shared';
import { sanityImageUrl } from '@lib/image';

interface Props {
  heading: string;
  tagline?: string;
  image?: SanityImageType;
  ctaText?: string;
  ctaUrl?: string;
}

const { heading, tagline, image, ctaText, ctaUrl } = Astro.props;

const bgImageUrl = image ? sanityImageUrl(image, 1200, 900) : null;
---

<section class="hero" aria-label="Hero">
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-content-inner">
        <h1 class="hero-heading">{heading}</h1>
        {tagline && <p class="hero-tagline">{tagline}</p>}
        {ctaText && ctaUrl && (
          <a href={ctaUrl} class="hero-cta" {...(ctaUrl.includes('phorest') && { 'data-booking': '' })}>
            {ctaText}
          </a>
        )}
      </div>
    </div>
    <div class="hero-media">
      {bgImageUrl ? (
        <img
          src={bgImageUrl}
          alt=""
          class="hero-image"
          loading="eager"
          decoding="async"
        />
      ) : (
        <img src="/images/hero.jpg" alt="" class="hero-image" loading="eager" decoding="async" fetchpriority="high" width="1600" height="1600" />
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 70vh;
  }

  /* Content panel — blush/accent background */
  .hero-content {
    background-color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-12) var(--space-6);
  }

  .hero-content-inner {
    max-width: 32rem;
  }

  .hero-heading {
    font-family: var(--font-heading);
    font-size: var(--font-size-4xl);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-primary);
    margin-bottom: var(--space-4);
    letter-spacing: -0.01em;
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    line-height: 1.7;
    color: var(--color-neutral-600);
    margin-bottom: var(--space-8);
  }

  .hero-cta {
    display: inline-block;
    padding: var(--space-3) var(--space-8);
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-white);
    background-color: var(--color-primary);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: background-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .hero-cta:hover {
    background-color: var(--color-primary-dark);
    box-shadow: var(--shadow-md);
  }

  .hero-cta:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* Media panel — image side */
  .hero-media {
    position: relative;
    overflow: hidden;
    min-height: 300px;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Desktop: side-by-side split layout */
  @media (min-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr 1fr;
      min-height: 75vh;
    }

    .hero-content {
      padding: var(--space-16) var(--space-12);
    }

    .hero-heading {
      font-size: var(--font-size-5xl);
    }

    .hero-tagline {
      font-size: var(--font-size-lg);
    }
  }

  @media (min-width: 1024px) {
    .hero-content {
      padding: var(--space-20) var(--space-16);
    }
  }
</style>

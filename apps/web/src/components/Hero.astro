---
import type { SanityImage as SanityImageType } from '@foxhue/shared';
import { sanityImageUrl } from '@lib/image';

interface Props {
  heading: string;
  tagline?: string;
  image?: SanityImageType;
  ctaText?: string;
  ctaUrl?: string;
  eyebrow?: string;
  secondaryCtaText?: string;
  secondaryCtaUrl?: string;
}

const { heading, tagline, image, ctaText, ctaUrl, eyebrow, secondaryCtaText, secondaryCtaUrl } = Astro.props;

const bgImageUrl = image ? sanityImageUrl(image, 1920, 1080) : null;
---

<section class="hero" aria-labelledby="hero-heading" data-hero>
  <div class="hero-image-wrapper">
    {bgImageUrl ? (
      <img
        src={bgImageUrl}
        alt=""
        class="hero-image"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="1080"
      />
    ) : (
      <img src="/images/hero.jpg" alt="" class="hero-image" loading="eager" fetchpriority="high" width="1920" height="1080" />
    )}
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content container">
    <div class="hero-content-inner">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h1 id="hero-heading" class="hero-heading">{heading}</h1>
      {tagline && <p class="hero-tagline">{tagline}</p>}
      <div class="hero-cta-group">
        {ctaText && ctaUrl && (
          <a href={ctaUrl} class="hero-cta hero-cta--primary"
             {...(ctaUrl?.includes('phorest') && { 'data-booking': '' })}>
            {ctaText}
          </a>
        )}
        {secondaryCtaText && secondaryCtaUrl && (
          <a href={secondaryCtaUrl} class="hero-cta hero-cta--outline">
            {secondaryCtaText}
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  /* Full-bleed background image */
  .hero-image-wrapper {
    position: absolute;
    inset: 0;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Dark overlay — darker at top (nav readability) and bottom (text readability) */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.4) 0%,
      rgba(0, 0, 0, 0.15) 40%,
      rgba(0, 0, 0, 0.5) 100%
    );
  }

  /* Content sits at bottom-left */
  .hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-top: var(--space-24);
    padding-bottom: var(--space-16);
  }

  .hero-content-inner {
    max-width: 36rem;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
  }

  .eyebrow {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: var(--font-weight-heading-regular);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: var(--space-4);
  }

  .hero-heading {
    font-family: var(--font-heading);
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-heading-light);
    line-height: 1.15;
    color: var(--color-white);
    margin-bottom: var(--space-5);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-body-light);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-8);
    letter-spacing: var(--body-letter-spacing);
  }

  .hero-cta-group {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-8);
    font-family: var(--font-body);
    font-weight: var(--font-weight-body-medium);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: var(--radius-full);
    text-decoration: none;
    border: 1px solid transparent;
    transition: background-color var(--transition-base), color var(--transition-base), border-color var(--transition-base);
  }

  .hero-cta--primary {
    background-color: var(--color-secondary);
    color: var(--color-white);
    border-color: var(--color-secondary);
  }

  .hero-cta--primary:hover {
    background-color: var(--color-secondary-dark);
    border-color: var(--color-secondary-dark);
  }

  .hero-cta--outline {
    background-color: transparent;
    color: var(--color-white);
    border-color: var(--color-white);
  }

  .hero-cta--outline:hover {
    background-color: var(--color-white);
    color: var(--color-primary);
  }

  .hero-cta:focus-visible {
    outline: 2px solid var(--color-white);
    outline-offset: 2px;
  }

  /* Desktop */
  @media (min-width: 768px) {
    .hero-content {
      padding-bottom: var(--space-20);
    }

    .hero-heading {
      font-size: var(--font-size-5xl);
    }

    .hero-tagline {
      font-size: var(--font-size-lg);
    }
  }

  @media (min-width: 1024px) {
    .hero-content {
      padding-bottom: var(--space-24);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-cta {
      transition: none;
    }
  }
</style>

---
import type { SanityImage } from '@foxhue/shared';
import { sanityImageUrl } from '@lib/image';

interface Props {
  siteName: string;
  logo?: SanityImage;
}

const { siteName, logo } = Astro.props;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="header-inner container">
    <a href="/" class="logo-link" aria-label={`${siteName} - Home`}>
      {logo ? (
        <img
          src={sanityImageUrl(logo, 160, 48)}
          alt={siteName}
          class="logo-image"
          width="160"
          height="48"
        />
      ) : (
        <span class="logo-text">{siteName}</span>
      )}
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-checkbox sr-only" aria-hidden="true" />
    <label for="nav-toggle" class="nav-toggle" aria-label="Toggle navigation menu">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </label>

    <nav class="main-nav" aria-label="Main navigation">
      <ul class="nav-list" role="list">
        {navItems.map((item) => (
          <li class="nav-item">
            <a
              href={item.href}
              class:list={['nav-link', { 'nav-link--active': currentPath === item.href }]}
              aria-current={currentPath === item.href ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-neutral-200);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    min-height: 4rem;
  }

  /* Logo */
  .logo-link {
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-image {
    height: 2rem;
    width: auto;
  }

  .logo-text {
    font-family: var(--font-heading);
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-neutral-900);
  }

  /* Checkbox (visually hidden, drives menu state) */
  .nav-checkbox {
    position: absolute;
  }

  /* Mobile hamburger toggle */
  .nav-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.5rem;
    height: 2.5rem;
    padding: var(--space-2);
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: background-color var(--transition-fast);
    order: 1;
  }

  .nav-toggle:hover {
    background-color: var(--color-neutral-100);
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-neutral-700);
    border-radius: 1px;
    transition: transform var(--transition-base), opacity var(--transition-base);
    transform-origin: center;
  }

  /* Navigation panel */
  .main-nav {
    display: none;
    flex-basis: 100%;
    background-color: var(--color-white);
    border-top: 1px solid var(--color-neutral-200);
    order: 2;
  }

  .nav-list {
    display: flex;
    flex-direction: column;
    padding: var(--space-4) 0;
  }

  .nav-link {
    display: block;
    padding: var(--space-3) var(--space-4);
    font-size: var(--font-size-base);
    font-weight: 500;
    color: var(--color-neutral-700);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), background-color var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-primary);
    background-color: var(--color-neutral-50);
  }

  .nav-link--active {
    color: var(--color-primary);
    font-weight: 600;
  }

  /* Checkbox hack: show nav when checked */
  .nav-checkbox:checked ~ .main-nav {
    display: block;
  }

  /* Hamburger animation when open */
  .nav-checkbox:checked ~ .nav-toggle .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .nav-checkbox:checked ~ .nav-toggle .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .nav-checkbox:checked ~ .nav-toggle .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Desktop layout */
  @media (min-width: 768px) {
    .header-inner {
      flex-wrap: nowrap;
    }

    .nav-toggle {
      display: none;
    }

    .nav-checkbox {
      display: none;
    }

    .main-nav {
      display: block;
      flex-basis: auto;
      background: none;
      border: none;
      order: 1;
    }

    .nav-list {
      flex-direction: row;
      gap: var(--space-1);
      padding: 0;
    }

    .nav-link {
      padding: var(--space-2) var(--space-3);
    }
  }
</style>

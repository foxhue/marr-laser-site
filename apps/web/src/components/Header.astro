---
import type { SanityImage } from '@foxhue/shared';
import { sanityImageUrl } from '@lib/image';
import { BOOKING_LINK } from '@lib/constants';

interface Props {
  siteName: string;
  logo?: SanityImage;
}

const { siteName, logo } = Astro.props;

const treatmentCategories = [
  { label: 'Laser Treatments', href: '/services/laser-treatments' },
  { label: 'Skin Treatments', href: '/services/skin-treatments' },
  { label: 'Aesthetic Treatments', href: '/services/aesthetic-treatments' },
  { label: 'PMU Treatments', href: '/services/pmu-treatments' },
  { label: 'CACI Treatments', href: '/services/caci-treatments' },
];

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Treatments', href: '/services', children: treatmentCategories },
  { label: 'Pricing', href: '/pricing' },
  { label: 'About', href: '/about' },
  { label: 'Team', href: '/team' },
  { label: 'FAQ', href: '/faq' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const bookingUrl = BOOKING_LINK;
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="header-inner container">
    <div class="header-top">
      <a href="/" class="logo-link" aria-label={`${siteName} - Home`}>
        {logo ? (
          <img
            src={sanityImageUrl(logo, 200, 60)}
            alt={siteName}
            class="logo-image"
            width="200"
            height="60"
          />
        ) : (
          <img src="/logos/marr-wordmark-dark.svg" alt={siteName} class="logo-image" width="180" height="48" />
        )}
      </a>
    </div>

    <input type="checkbox" id="nav-toggle" class="nav-checkbox sr-only" aria-hidden="true" />
    <label for="nav-toggle" class="nav-toggle" aria-label="Toggle navigation menu">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </label>

    <nav class="main-nav" aria-label="Main navigation">
      <ul class="nav-list" role="list">
        {navItems.map((item) => (
          <li class:list={['nav-item', { 'nav-item--has-dropdown': item.children }]}>
            <a
              href={item.href}
              class:list={['nav-link', { 'nav-link--active': currentPath === item.href || (item.children && currentPath.startsWith('/services/')) }]}
              aria-current={currentPath === item.href ? 'page' : undefined}
              aria-haspopup={item.children ? 'true' : undefined}
              aria-expanded={item.children ? 'false' : undefined}
            >
              {item.label}
              {item.children && <span class="dropdown-arrow" aria-hidden="true">&#9662;</span>}
            </a>
            {item.children && (
              <ul class="dropdown" role="list">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class:list={['dropdown-link', { 'dropdown-link--active': currentPath === child.href }]}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
      <a href={bookingUrl} data-booking class="book-now-btn mobile-book-now">
        Book Now
      </a>
    </nav>

    <a href={bookingUrl} data-booking class="book-now-btn desktop-book-now">
      Book Now
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-neutral-100);
    border-bottom: 1px solid rgba(60, 60, 59, 0.1);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    min-height: 4.5rem;
  }

  /* Logo */
  .header-top {
    flex-shrink: 0;
  }

  .logo-link {
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .logo-image {
    height: 2.5rem;
    width: auto;
  }

  /* Checkbox (visually hidden, drives menu state) */
  .nav-checkbox {
    position: absolute;
  }

  /* Mobile hamburger toggle */
  .nav-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.5rem;
    height: 2.5rem;
    padding: var(--space-2);
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: background-color var(--transition-fast);
    order: 1;
  }

  .nav-toggle:hover {
    background-color: var(--color-accent);
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 1.5px;
    background-color: var(--color-neutral-700);
    border-radius: 1px;
    transition: transform var(--transition-base), opacity var(--transition-base);
    transform-origin: center;
  }

  /* Navigation panel */
  .main-nav {
    display: none;
    flex-basis: 100%;
    background-color: var(--color-white);
    border-top: 1px solid var(--color-accent);
    order: 2;
  }

  .nav-list {
    display: flex;
    flex-direction: column;
    padding: var(--space-4) 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: var(--font-weight-heading-regular);
    color: var(--color-neutral-800);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background-color: transparent;
    border-radius: var(--radius-full);
    transition: background-color var(--transition-base), color var(--transition-base);
  }

  .nav-link:hover {
    background-color: var(--color-secondary);
    color: var(--color-white);
  }

  .nav-link--active {
    background-color: var(--color-secondary);
    color: var(--color-white);
  }

  /* Dropdown arrow */
  .dropdown-arrow {
    font-size: 0.6em;
    transition: transform var(--transition-fast);
  }

  /* Dropdown menu */
  .dropdown {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .dropdown-link {
    display: block;
    padding: var(--space-2) var(--space-4) var(--space-2) var(--space-8);
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-body-light);
    color: var(--color-neutral-700);
    text-decoration: none;
    letter-spacing: var(--body-letter-spacing);
    border-radius: var(--radius-full);
    transition: color var(--transition-fast), background-color var(--transition-fast);
  }

  .dropdown-link:hover {
    color: var(--color-primary);
    background-color: var(--color-accent);
  }

  .dropdown-link--active {
    color: var(--color-primary);
    font-weight: 500;
  }

  /* Book Now button */
  .book-now-btn {
    display: inline-block;
    padding: var(--space-2) var(--space-6);
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: var(--font-weight-heading-regular);
    color: var(--color-white);
    background-color: var(--color-secondary);
    border: 1px solid var(--color-secondary);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: var(--radius-lg);
    transition: background-color var(--transition-fast), box-shadow var(--transition-fast);
    white-space: nowrap;
  }

  .book-now-btn:hover {
    background-color: var(--color-secondary-dark);
  }

  .book-now-btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* Mobile: show book now inside menu, hide desktop one */
  .mobile-book-now {
    display: block;
    text-align: center;
    margin: var(--space-4);
  }

  .desktop-book-now {
    display: none;
  }

  /* Checkbox hack: show nav when checked */
  .nav-checkbox:checked ~ .main-nav {
    display: block;
  }

  /* Hamburger animation when open */
  .nav-checkbox:checked ~ .nav-toggle .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .nav-checkbox:checked ~ .nav-toggle .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .nav-checkbox:checked ~ .nav-toggle .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Desktop layout */
  @media (min-width: 768px) {
    .header-inner {
      display: grid;
      grid-template-columns: 1fr;
      justify-items: center;
      gap: var(--space-2);
      padding-block: var(--space-3);
    }

    .nav-toggle {
      display: none;
    }

    .nav-checkbox {
      display: none;
    }

    .main-nav {
      grid-row: 2;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      background: none;
      border: none;
    }

    .nav-list {
      flex-direction: row;
      justify-content: center;
      gap: var(--space-1);
      padding: 0;
    }

    .nav-link {
      padding: var(--space-2) var(--space-4);
    }

    /* Desktop dropdown: hidden by default, shown on hover/focus */
    .dropdown {
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      min-width: 14rem;
      background-color: var(--color-white);
      border: 1px solid rgba(60, 60, 59, 0.1);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-card);
      padding: var(--space-2) 0;
      opacity: 0;
      visibility: hidden;
      transition: opacity var(--transition-fast), visibility var(--transition-fast);
      z-index: 200;
    }

    .dropdown-link {
      padding: var(--space-2) var(--space-4);
    }

    .nav-item--has-dropdown:hover > .dropdown,
    .nav-item--has-dropdown:focus-within > .dropdown {
      opacity: 1;
      visibility: visible;
    }

    .nav-item--has-dropdown:hover .dropdown-arrow {
      transform: rotate(180deg);
    }

    /* Desktop: Book Now sits on the same row as nav, pinned right */
    .mobile-book-now {
      display: none;
    }

    .desktop-book-now {
      display: inline-block;
      grid-row: 2;
      justify-self: end;
      align-self: center;
    }
  }
</style>
